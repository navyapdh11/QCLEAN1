{
  "rewrites": [
    {
      "source": "/api/booking/:path*",
      "destination": "https://booking-service.primeclean.svc.cluster.local/:path*"
    },
    {
      "source": "/api/rag/:path*",
      "destination": "https://rag-service.primeclean.svc.cluster.local/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
